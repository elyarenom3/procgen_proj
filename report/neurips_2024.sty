\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 Minimal NeurIPS-style package]
\newif\if@neuripsfinal
\@neuripsfinaltrue
\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripsfinaltrue}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax
\RequirePackage[margin=1in]{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{natbib}
\RequirePackage{microtype}
\RequirePackage{times}
\setlength{\columnsep}{0.25in}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}
\titleformat{\section}{\large\bfseries}{\thesection}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.5em}{}
\titlespacing*{\section}{0pt}{1.4ex plus 0.4ex minus 0.2ex}{0.6ex}
\titlespacing*{\subsection}{0pt}{1.0ex plus 0.3ex minus 0.2ex}{0.5ex}
\renewcommand{\maketitle}{%
  \begin{center}%
    {\LARGE \bfseries \@title \par}%
    \vspace{0.7em}%
    {\normalsize \@author \par}%
    \vspace{0.9em}%
  \end{center}%
}
